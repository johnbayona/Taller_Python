
intentos = 0


def generar_numero():

    return 50


def verificar_adivinanza(secreto, intento):

    if intento == secreto:
        return "correcto"

    elif intento < secreto:
        return "mayor"

    else:
        return "menor"


def contar_intento():

    global intentos

    intentos += 1


def mostrar_estadisticas(secreto):

    print("Número secreto:", secreto)

    print("Intentos realizados:", intentos)


numero_secreto = generar_numero()


while True:

    numero_usuario = int(input("Adivina el número: "))

    contar_intento()

    resultado = verificar_adivinanza(numero_secreto, numero_usuario)

    if resultado == "correcto":

        print("¡Correcto!")
        break

    elif resultado == "mayor":

        print("El número secreto es mayor")

    else:

        print("El número secreto es menor")


mostrar_estadisticas(numero_secreto)