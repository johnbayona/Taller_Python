
import random

class Cancion:
    def __init__(self, titulo, artista, duracion_segundos):
        self.titulo = titulo
        self.artista = artista
        self.duracion = duracion_segundos

    def __str__(self):
        minutos = self.duracion // 60
        segundos = self.duracion % 60
        return f"{self.titulo} - {self.artista} ({minutos}:{segundos:02d})"

class Playlist:
    def __init__(self, nombre):
        self.nombre = nombre
        self.canciones = []
        self.indice_actual = 0

    def agregar_cancion(self, titulo, artista, duracion):
        nueva_cancion = Cancion(titulo, artista, duracion)
        self.canciones.append(nueva_cancion)

    def reproducir_actual(self):
        if not self.canciones:
            print("Lista vacía")
            return
        print(f"Reproduciendo: {self.canciones[self.indice_actual]}")

    def siguiente(self):
        if self.canciones:
            self.indice_actual = (self.indice_actual + 1) % len(self.canciones)
            self.reproducir_actual()

    def anterior(self):
        if self.canciones:
            self.indice_actual = (self.indice_actual - 1) % len(self.canciones)
            self.reproducir_actual()

    def modo_aleatorio(self):
        if len(self.canciones) > 1:
            random.shuffle(self.canciones)
            self.indice_actual = 0
            self.reproducir_actual()

    def buscar_cancion(self, termino):
        resultados = [c for c in self.canciones if termino.lower() in c.titulo.lower() or termino.lower() in c.artista.lower()]
        for c in resultados:
            print(f"Encontrada: {c}")

    def duracion_total(self):
        total = sum(c.duracion for c in self.canciones)
        horas = total // 3600
        minutos = (total % 3600) // 60
        segundos = total % 60
        print(f"Total: {horas}h {minutos}m {segundos}s")

mi_playlist = Playlist("Favoritos")
mi_playlist.agregar_cancion("Blinding Lights", "The Weeknd", 200)
mi_playlist.agregar_cancion("Bohemian Rhapsody", "Queen", 354)
mi_playlist.agregar_cancion("Shape of You", "Ed Sheeran", 233)

mi_playlist.reproducir_actual()
mi_playlist.siguiente()
mi_playlist.duracion_total()
mi_playlist.buscar_cancion("Queen")
mi_playlist.modo_aleatorio()